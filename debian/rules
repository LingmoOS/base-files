#!/usr/bin/make -f

include /usr/share/dpkg/architecture.mk

# ========== Lingmo OS 统一版本配置（修改此处即可全局生效） ==========
DISTRO_NAME  = Lingmo OS
VERSION      = 5.0
CODENAME     = Lithium
codename     = lithium
DEBIAN_VER   = 13.5
# 内部构建版本（格式：YY[R|b|a]NN）
BUILD_VER    ?= 26a01
VARIANT      = Desktop
variant_id   = desktop
# ===================================================================

OSNAME = "GNU/`uname | sed -e 's/GNU\///'`"
ifeq ($(DEB_HOST_GNU_SYSTEM),linux)
  OSNAME=GNU/Linux
endif
ifeq ($(DEB_HOST_GNU_SYSTEM),gnu)
  OSNAME=GNU/Hurd
endif

VENDORFILE = debian
DESTDIR = debian/base-files

ifneq (,$(filter $(DEB_HOST_ARCH),amd64 loong64 mips64el ppc64 ppc64el sparc64))
  USR_MERGE_RTLDLIB = lib64
else ifneq (,$(filter $(DEB_HOST_ARCH),x32))
  USR_MERGE_RTLDLIB = libx32
endif
USR_MERGE = bin lib sbin $(USR_MERGE_RTLDLIB)
USR_MERGE_MULTILIB = $(filter-out $(USR_MERGE),lib32 lib64 libo32 libx32)

%:
	dh $@

execute_after_dh_clean:
	sh debian/timestamps

override_dh_auto_build:
	sh debian/check-md5sum-etc profile
	sh debian/check-md5sum-etc dot.profile
	set -e; { \
	  echo "# Triggers for creating multilib aliasing symlinks on demand"; \
	  for d in $(USR_MERGE_MULTILIB); do \
	    echo "interest-noawait /usr/$$d"; \
	  done; \
	} > debian/triggers

execute_after_dh_installdirs:
	dh_installdirs $(foreach d,$(USR_MERGE),usr/$(d))

override_dh_auto_install:
	install -p -m 644 etc/*      $(DESTDIR)/etc
	install -p -m 755 motd/*     $(DESTDIR)/etc/update-motd.d
	install -p -m 644 licenses/* $(DESTDIR)/usr/share/common-licenses
	install -p -m 644 origins/*  $(DESTDIR)/etc/dpkg/origins
	install -p -m 644 share/*    $(DESTDIR)/usr/share/base-files
	# Install Lingmo OS custom system/vendor files (use cp -r for directories)
	cp -r system/*   $(DESTDIR)/system/
	cp -r vendor/*   $(DESTDIR)/vendor/
	# Set proper permissions for info files
	find $(DESTDIR)/system -type f -exec chmod 644 {} \;
	find $(DESTDIR)/vendor -type f -exec chmod 644 {} \;
ifeq ($(DEB_HOST_GNU_SYSTEM),gnu)
	rmdir $(DESTDIR)/sys
endif
	sed -e "s&#OSNAME#&$(OSNAME)&g" \
	    -e "s|@DISTRO_NAME@|$(DISTRO_NAME)|g" \
	    -e "s|@VERSION@|$(VERSION)|g" \
	    -e "s|@CODENAME@|$(CODENAME)|g" \
	    -e "s|@BUILD_VER@|$(BUILD_VER)|g" \
	    -e "s|@VERSION_TYPE@|$(shell echo $(BUILD_VER) | grep -q 'a' && echo Alpha || (echo $(BUILD_VER) | grep -q 'b' && echo Beta || echo Release))|g" share/motd     > $(DESTDIR)/usr/share/base-files/motd
	sed -e "s&#OSNAME#&$(OSNAME)&g" share/info.dir > $(DESTDIR)/usr/share/base-files/info.dir
	sed -e "s&#OSNAME#&$(OSNAME)&g" \
	    -e "s|@DISTRO_NAME@|$(DISTRO_NAME)|g" \
	    -e "s|@VERSION@|$(VERSION)|g" \
	    -e "s|@CODENAME@|$(CODENAME)|g" etc/issue      > $(DESTDIR)/etc/issue
	sed -e "s&#OSNAME#&$(OSNAME)&g" \
	    -e "s|@DISTRO_NAME@|$(DISTRO_NAME)|g" \
	    -e "s|@VERSION@|$(VERSION)|g" \
	    -e "s|@CODENAME@|$(CODENAME)|g" etc/issue.net  > $(DESTDIR)/etc/issue.net
	sed -e "s&#OSNAME#&$(OSNAME)&g" etc/os-release \
	    -e "s|@DISTRO_NAME@|$(DISTRO_NAME)|g" \
	    -e "s|@VERSION@|$(VERSION)|g" \
	    -e "s|@CODENAME@|$(CODENAME)|g" \
	    -e "s|@codename@|$(codename)|g" \
	    -e "s|@DEBIAN_VER@|$(DEBIAN_VER)|g" \
	    -e "s|@BUILD_VER@|$(BUILD_VER)|g" \
	    -e "s|@VERSION_TYPE@|$(shell echo $(BUILD_VER) | grep -q 'a' && echo Alpha || (echo $(BUILD_VER) | grep -q 'b' && echo Beta || echo Release))|g" \
	    -e "s|@VARIANT@|$(VARIANT)|g" \
	    -e "s|@variant_id@|$(variant_id)|g" \
	    -e "s|\$$(shell date +%Y%m%d)|$(shell date +%Y%m%d)|g" \
	    > $(DESTDIR)/etc/os-release
	sed -e "s|@DEBIAN_VER@|$(DEBIAN_VER)|g" etc/debian_version > $(DESTDIR)/etc/debian_version
	mv $(DESTDIR)/etc/os-release $(DESTDIR)/usr/lib/os-release
	ln -s ../usr/lib/os-release $(DESTDIR)/etc/os-release
	# Process Lingmo OS custom system files with variable substitution
	sed -e "s|@DISTRO_NAME@|$(DISTRO_NAME)|g" \
	    -e "s|@VERSION@|$(VERSION)|g" \
	    -e "s|@CODENAME@|$(CODENAME)|g" \
	    -e "s|@BUILD_VER@|$(BUILD_VER)|g" \
	    -e "s|@VERSION_TYPE@|$(shell echo $(BUILD_VER) | grep -q 'a' && echo Alpha || (echo $(BUILD_VER) | grep -q 'b' && echo Beta || echo Release))|g" \
	    -e "s|@VARIANT@|$(VARIANT)|g" \
	    -e "s|@variant_id@|$(variant_id)|g" \
	    -e "s|@DEBIAN_VER@|$(DEBIAN_VER)|g" \
	    -e "s|@ARCH@|$(DEB_HOST_ARCH)|g" \
	    system/version_sys > $(DESTDIR)/system/version_sys
	sed -e "s|@BUILD_VER@|$(BUILD_VER)|g" \
	    system/.version > $(DESTDIR)/system/.version
	sed -e "s|@DISTRO_NAME@|$(DISTRO_NAME)|g" \
	    -e "s|@VERSION@|$(VERSION)|g" \
	    -e "s|@codename@|$(codename)|g" \
	    -e "s|@BUILD_VER@|$(BUILD_VER)|g" \
	    -e "s|@VERSION_TYPE@|$(shell echo $(BUILD_VER) | grep -q 'a' && echo Alpha || (echo $(BUILD_VER) | grep -q 'b' && echo Beta || echo Release))|g" \
	    -e "s|@DEBIAN_VER@|$(DEBIAN_VER)|g" \
	    -e "s|@VARIANT@|$(VARIANT)|g" \
	    -e "s|@variant_id@|$(variant_id)|g" \
	    -e "s|\$$(shell date +%Y%m%d)|$(shell date +%Y%m%d)|g" \
	    system/release > $(DESTDIR)/system/release
	# Process vendor files
	sed -e "s|@BUILD_VER@|$(BUILD_VER)|g" \
	    -e "s|@VERSION_TYPE@|$(shell echo $(BUILD_VER) | grep -q 'a' && echo Alpha || (echo $(BUILD_VER) | grep -q 'b' && echo Beta || echo Release))|g" \
	    vendor/vendor_info > $(DESTDIR)/vendor/vendor_info
	sed -e "s|@BUILD_VER@|$(BUILD_VER)|g" \
	    vendor/.version > $(DESTDIR)/vendor/.version
	# Process system subdirectory info files
	sed -e "s|@DISTRO_NAME@|$(DISTRO_NAME)|g" \
	    -e "s|@VERSION@|$(VERSION)|g" \
	    -e "s|@CODENAME@|$(CODENAME)|g" \
	    -e "s|@BUILD_VER@|$(BUILD_VER)|g" \
	    -e "s|@VERSION_TYPE@|$(shell echo $(BUILD_VER) | grep -q 'a' && echo Alpha || (echo $(BUILD_VER) | grep -q 'b' && echo Beta || echo Release))|g" \
	    system/etc/README.system > $(DESTDIR)/system/etc/README.system
	sed -e "s|@DISTRO_NAME@|$(DISTRO_NAME)|g" \
	    -e "s|@VERSION@|$(VERSION)|g" \
	    -e "s|@BUILD_VER@|$(BUILD_VER)|g" \
	    system/bin/README.bin > $(DESTDIR)/system/bin/README.bin
	sed -e "s|@DISTRO_NAME@|$(DISTRO_NAME)|g" \
	    -e "s|@VERSION@|$(VERSION)|g" \
	    -e "s|@BUILD_VER@|$(BUILD_VER)|g" \
	    -e "s|@ARCH@|$(DEB_HOST_ARCH)|g" \
	    system/lib/README.lib > $(DESTDIR)/system/lib/README.lib
	sed -e "s|@DISTRO_NAME@|$(DISTRO_NAME)|g" \
	    -e "s|@VERSION@|$(VERSION)|g" \
	    -e "s|@BUILD_VER@|$(BUILD_VER)|g" \
	    system/include/README.include > $(DESTDIR)/system/include/README.include
	sed -e "s|@DISTRO_NAME@|$(DISTRO_NAME)|g" \
	    -e "s|@VERSION@|$(VERSION)|g" \
	    -e "s|@CODENAME@|$(CODENAME)|g" \
	    -e "s|@BUILD_VER@|$(BUILD_VER)|g" \
	    system/share/README.share > $(DESTDIR)/system/share/README.share
	# Process vendor subdirectory info files
	sed -e "s|@DISTRO_NAME@|$(DISTRO_NAME)|g" \
	    -e "s|@VERSION@|$(VERSION)|g" \
	    -e "s|@CODENAME@|$(CODENAME)|g" \
	    -e "s|@BUILD_VER@|$(BUILD_VER)|g" \
	    vendor/etc/README.vendor > $(DESTDIR)/vendor/etc/README.vendor
	sed -e "s|@DISTRO_NAME@|$(DISTRO_NAME)|g" \
	    -e "s|@VERSION@|$(VERSION)|g" \
	    -e "s|@BUILD_VER@|$(BUILD_VER)|g" \
	    vendor/bin/README.bin > $(DESTDIR)/vendor/bin/README.bin
	sed -e "s|@DISTRO_NAME@|$(DISTRO_NAME)|g" \
	    -e "s|@VERSION@|$(VERSION)|g" \
	    -e "s|@BUILD_VER@|$(BUILD_VER)|g" \
	    vendor/lib/README.lib > $(DESTDIR)/vendor/lib/README.lib
	sed -e "s|@DISTRO_NAME@|$(DISTRO_NAME)|g" \
	    -e "s|@VERSION@|$(VERSION)|g" \
	    -e "s|@BUILD_VER@|$(BUILD_VER)|g" \
	    vendor/firmware/README.firmware > $(DESTDIR)/vendor/firmware/README.firmware
	sed -e "s|@DISTRO_NAME@|$(DISTRO_NAME)|g" \
	    -e "s|@VERSION@|$(VERSION)|g" \
	    -e "s|@BUILD_VER@|$(BUILD_VER)|g" \
	    vendor/share/README.share > $(DESTDIR)/vendor/share/README.share

override_dh_installchangelogs:
	dh_installchangelogs --no-trim

override_dh_link:
	dh_link -X os-release
	# We want these links to be relative, so we cannot use dh_link.
	set -e; for d in $(USR_MERGE); do \
	  ln -s usr/$$d debian/base-files/$$d; \
	done

override_dh_compress:
	dh_compress -X README

override_dh_fixperms:
	dh_fixperms
	cd debian/base-files && chmod 755  `find . -type d`
	cd debian/base-files && chmod 1777 `cat ../1777-dirs`
	cd debian/base-files && chmod 700 root

override_dh_installdeb:
	dh_installdeb \
	  '-DVENDORFILE=$(VENDORFILE)' \
	  '-DUSR_MERGE_MULTILIB=$(USR_MERGE_MULTILIB)' \
	  '-DUSR_MERGE_RTLDLIB=$(USR_MERGE_RTLDLIB)'
